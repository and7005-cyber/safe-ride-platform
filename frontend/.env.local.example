VITE_API_BASE_URL=http://localhost:9001

# Google Maps JavaScript API browser key (HTTP-referrer restricted). Required for
# the embedded Google Maps (Fleet Map, route planner, address pickers, parent
# tracking). Create one in Google Cloud → APIs & Services → Credentials and
# enable: Maps JavaScript API, Places API, Geocoding API, Maps Embed API.
VITE_GOOGLE_MAPS_API_KEY=
