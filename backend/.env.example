APP_ENV=local
API_PORT=9001
POSTGRES_DB=saferide
POSTGRES_USER=saferide
POSTGRES_PASSWORD=saferide
DATABASE_URL=postgresql://saferide:saferide@db:5432/saferide
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEMO_SCHOOL_ID=11111111-1111-1111-1111-111111111111
PIN_PEPPER=saferide-local-pin-pepper
APP_BASE_URL=http://localhost:5173

# Reverse proxy: only enable when every request passes through a proxy that
# overwrites X-Forwarded-For (rate limiting trusts it for the client IP).
TRUST_PROXY_HEADERS=false

# Push notifications (all optional — without them delivery is simulated and
# the in-app notification feed still works).
# Firebase Cloud Messaging: service account JSON (inline JSON or a file path).
FIREBASE_SERVICE_ACCOUNT_JSON=
# Firebase web app config JSON (apiKey, authDomain, projectId, messagingSenderId, appId).
FIREBASE_WEB_CONFIG_JSON=
# Firebase Cloud Messaging web push certificate key pair (public VAPID key).
FIREBASE_VAPID_KEY=
# Plain Web Push (VAPID) fallback, independent of Firebase.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@saferidekenya.com
# Radius in meters for "bus approaching" parent notifications.
BUS_APPROACHING_RADIUS_M=1000

# Maps provider for address geocoding + route optimisation (the Routes page,
# the student "Locate" button, and the Fleet Map route planner). Optional:
# with neither key set, geocoding falls back to free OpenStreetMap Nominatim
# and route ordering uses an offline nearest-neighbour heuristic. Set one to
# enable higher-quality geocoding and road-distance optimisation.
GOOGLE_MAPS_API_KEY=
MAPBOX_TOKEN=
